---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import profileImage from "../assets/profile.jpg";
import { SITE_AUTHOR, SITE_TITLE } from "../consts";

const homeTitle = `${SITE_TITLE} | ${SITE_AUTHOR}`;
const homeDescription =
	"Abhigyan Mohanta is a software engineer and CNCF Kubestronaut building Kubernetes, AI-native infrastructure, real-time systems, and practical fullstack applications.";

const currentSignals = [
	"RL-driven Kubernetes Scheduling",
	"Real-time Media Pipelines",
	"Multi-LLM Architectures",
	"MCP Clients & Voice Agents",
	"Go & Elixir Backends",
	"FullStack AI-Native Applications",
	"Concurrency",
];

const calendlyUrl = "https://calendly.com/cloudnativeabhigyan/30min";
const recommendationsUrl =
	"https://www.linkedin.com/in/abhigyan-mohanta/details/recommendations/";

const profileLinks = [
	{ label: "GitHub", href: "https://github.com/ABHIGYAN-MOHANTA" },
	{
		label: "LinkedIn",
		href: "https://www.linkedin.com/in/abhigyan-mohanta/",
	},
	{ label: "X", href: "https://x.com/MohantaAbhigyan" },
	{ label: "Book a call", href: calendlyUrl },
];

const techStack = [
	"Go",
	"Python",
	"TypeScript",
	"React.js",
	"Node.js",
	"HTML5",
	"CSS3",
	"Kubernetes",
	"Terraform",
	"AWS",
	"GCP",
	"LLMs",
	"RAG",
	"Vector Databases",
	"Google Gemini",
	"Scikit-Learn",
	"PyTorch",
	"PostgreSQL",
	"Apache Kafka",
	"gRPC",
	"Websockets",
];

